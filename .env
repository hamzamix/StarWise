# Fill these in with your own credentials
# 1. GitHub OAuth App settings
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# 2. Google Gemini API Key
# Get this from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key

# 3. A long, random string for securing session cookies
# You can generate one with: openssl rand -hex 32
SECRET_KEY=a_very_long_and_super_secret_random_string_for_security
